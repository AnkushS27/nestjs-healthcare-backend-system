generator client {
  provider = "prisma-client-js"
  output   = "./generated/main"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}

model User {
  id                    String                  @id @default(uuid())
  email                 String                  @unique
  password              String
  name                  String
  role                  Role                    @default(PATIENT)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
}