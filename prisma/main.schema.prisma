generator client {
  provider = "prisma-client-js"
  output   = "./generated/main"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}

model User {
  id                    Int                     @id @default(autoincrement())
  name                  String
  email                 String                  @unique
  password              String
  role                  Role
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
}